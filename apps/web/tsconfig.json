{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "useDefineForClassFields": true,
    "isolatedModules": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noEmit": true,
    "types": ["vite/client"],
    "baseUrl": ".",
    "paths": {
      "@renderer/*": ["../../packages/app-core/src/*"],
      "@shared/*": ["../../packages/shared-domain/src/*"],
      "@bridge-contract/*": ["../../packages/bridge-contract/src/*"],
      "@zennotes/app-core/*": ["../../packages/app-core/src/*"],
      "@zennotes/bridge-contract/*": ["../../packages/bridge-contract/src/*"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
