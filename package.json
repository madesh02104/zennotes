{
  "name": "zennotes",
  "productName": "ZenNotes",
  "version": "0.1.0",
  "description": "A keyboard-first markdown notes app with Vim motions and plain local files",
  "main": "./out/main/index.js",
  "author": "Adi Bhanna",
  "license": "MIT",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "start": "electron-vite preview",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "pack": "electron-vite build && electron-builder --dir",
    "dist:mac": "electron-vite build && electron-builder --mac",
    "dist:win": "electron-vite build && electron-builder --win",
    "dist:linux": "electron-vite build && electron-builder --linux"
  },
  "dependencies": {
    "@codemirror/autocomplete": "^6.18.3",
    "@codemirror/commands": "^6.7.1",
    "@codemirror/lang-markdown": "^6.3.1",
    "@codemirror/language": "^6.10.6",
    "@codemirror/language-data": "^6.5.1",
    "@codemirror/search": "^6.5.8",
    "@codemirror/state": "^6.5.0",
    "@codemirror/view": "^6.35.3",
    "@lezer/highlight": "^1.2.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@replit/codemirror-vim": "^6.3.0",
    "chokidar": "^4.0.3",
    "codemirror": "^6.0.1",
    "font-list": "^2.0.2",
    "function-plot": "^1.25.3",
    "fuse.js": "^7.0.0",
    "gray-matter": "^4.0.3",
    "highlight.js": "^11.10.0",
    "jsxgraph": "^1.12.2",
    "katex": "^0.16.15",
    "mermaid": "^11.4.1",
    "node-tikzjax": "^1.0.5",
    "prettier": "^3.8.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "rehype-highlight": "^7.0.1",
    "rehype-katex": "^7.0.1",
    "rehype-raw": "^7.0.0",
    "rehype-stringify": "^10.0.1",
    "remark-breaks": "^4.0.0",
    "remark-frontmatter": "^5.0.0",
    "remark-gfm": "^4.0.0",
    "remark-math": "^6.0.0",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.1",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.0.0",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.17",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2",
    "vite": "^5.4.11"
  },
  "build": {
    "appId": "com.adibhanna.zennotes",
    "executableName": "ZenNotes",
    "productName": "ZenNotes",
    "directories": {
      "buildResources": "build",
      "output": "dist"
    },
    "files": [
      "out/**/*",
      "!**/*.map"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "extendInfo": {
        "CFBundleName": "ZenNotes",
        "CFBundleDisplayName": "ZenNotes"
      },
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "target": [
        "nsis",
        "zip"
      ]
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Office"
    }
  }
}
